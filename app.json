{
  "expo": {
    "name": "Trimly",
    "slug": "healthApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "healthapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karimova008.healthApp",
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) mashq va poza tahlili uchun kameradan foydalanadi.",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) video yozish uchun mikrofondan foydalanadi."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.karimova008.healthApp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) mashq va poza tahlili uchun kameradan foydalanadi.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "$(PRODUCT_NAME) video yozish uchun mikrofondan foydalanadi.",
          "enableFrameProcessors": true
        }
      ],
      [
        "./plugins/withMediapipeModelAssets.js",
        {
          "assetsPaths": [
            "./assets/models/"
          ]
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ],
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4216862763820451~7049873121",
          "iosAppId": "ca-app-pub-4216862763820451~7049873121"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#1A0F3D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "expo-navigation-bar": {
        "visibility": "hidden",
        "behavior": "overlay-swipe"
      },
      "router": {},
      "eas": {
        "projectId": "18e6ceb3-bd03-42d5-add0-ed42eae80a2a"
      }
    }
  }
}
